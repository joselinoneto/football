    "about.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every team, every group, every match of the FIFA World Cup 2026 — fetched live from the tournament and kept on your device, so it works anywhere."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Todos os times, todos os grupos, todas as partidas da Copa do Mundo FIFA 2026 — buscadas ao vivo do torneio e guardadas no seu aparelho, para funcionar em qualquer lugar."
          }
        }
      }
    },
    "about.tagline": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Football and nothing else."
          }
